<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="br.edu.ufersa.sedan.controllers.PecaAdicionarController"
      stylesheets="@../css/style.css"
      styleClass="dialog-container"
      spacing="14" prefWidth="420">

    <Label text="Nova Peça no Estoque" styleClass="dialog-title"/>
    <Separator/>

    <VBox spacing="4">
        <Label text="Nome da Peça:" styleClass="form-label"/>
        <TextField fx:id="txtNome" promptText="Ex: Amortecedor Dianteiro" styleClass="form-field"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Fabricante:" styleClass="form-label"/>
        <TextField fx:id="txtFabricante" promptText="Ex: Cofap" styleClass="form-field"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Preço de Venda (R$):" styleClass="form-label"/>
        <TextField fx:id="txtPreco" promptText="0.00" styleClass="form-field"/>
    </VBox>

    <Label fx:id="lblErro" styleClass="error-label" wrapText="true"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" styleClass="btn-cancel" onAction="#onCancelar"/>
        <Button text="Salvar" styleClass="btn-submit" onAction="#onConfirmar"/>
    </HBox>
</VBox>