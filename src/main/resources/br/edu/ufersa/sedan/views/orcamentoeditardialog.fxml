<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="br.edu.ufersa.sedan.controllers.OrcamentoEditarController"
      stylesheets="@../css/style.css"
      styleClass="dialog-root"
      prefWidth="560" spacing="0">

    <padding><Insets top="28" right="28" bottom="24" left="28"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Editar Orçamento" styleClass="dialog-title"/>
        <Label text="✏" styleClass="dialog-title-icon"/>
    </HBox>

    <VBox spacing="0">
        <padding><Insets top="18" bottom="0"/></padding>

        <GridPane hgap="14" vgap="0">
            <columnConstraints>
                <ColumnConstraints percentWidth="50.0"/>
                <ColumnConstraints percentWidth="50.0"/>
            </columnConstraints>

            <Label text="VEÍCULO VINCULADO" styleClass="dialog-field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label text="DATA DE EMISSÃO" styleClass="dialog-field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <TextField fx:id="tfVeiculo" styleClass="dialog-field" editable="false" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <DatePicker fx:id="dpData" styleClass="dialog-field" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        </GridPane>

        <Region prefHeight="16"/>

        <GridPane hgap="14" vgap="0">
            <columnConstraints>
                <ColumnConstraints percentWidth="50.0"/>
                <ColumnConstraints percentWidth="50.0"/>
            </columnConstraints>

            <Label text="ATUALIZAR PEÇAS" styleClass="dialog-field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label text="ATUALIZAR SERVIÇOS" styleClass="dialog-field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <ListView fx:id="lvPecas" prefHeight="140" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <ListView fx:id="lvServicos" prefHeight="140" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <padding><Insets top="12" bottom="4"/></padding>
            <Label text="TOTAL ATUALIZADO:" styleClass="dialog-field-label" style="-fx-font-size: 13px;"/>
            <Label fx:id="lblTotal" text="R$ 0,00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
        </HBox>
    </VBox>

    <Label fx:id="lblErro" styleClass="dialog-error" wrapText="true">
        <VBox.margin><Insets top="4"/></VBox.margin>
    </Label>

    <HBox spacing="14" alignment="CENTER">
        <VBox.margin><Insets top="16"/></VBox.margin>
        <Button text="CANCELAR" styleClass="dialog-btn-red" prefWidth="180" onAction="#onCancelar"/>
        <Button text="CONFIRMAR" styleClass="dialog-btn-green" prefWidth="180" onAction="#onConfirmar"/>
    </HBox>
</VBox>