<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.edu.ufersa.sedan.controllers.RelatorioController"
            stylesheets="@../css/style.css"
            prefWidth="1000" prefHeight="650"
            styleClass="root">

    <left>
        <VBox styleClass="sidebar" prefWidth="180">
            <VBox spacing="0" VBox.vgrow="ALWAYS">

                <Button text="Clientes" styleClass="sidebar-item"
                        maxWidth="Infinity" onAction="#onClientes">
                    <graphic><Label text="👤"/></graphic>
                </Button>

                <Button text="Veículos" styleClass="sidebar-item"
                        maxWidth="Infinity" onAction="#onVeiculos">
                    <graphic><Label text="🚗"/></graphic>
                </Button>

                <Button text="Peças" styleClass="sidebar-item"
                        maxWidth="Infinity" onAction="#onPecas">
                    <graphic><Label text="⚙"/></graphic>
                </Button>

                <Button text="Serviços" styleClass="sidebar-item"
                        maxWidth="Infinity" onAction="#onServicos">
                    <graphic><Label text="🔧"/></graphic>
                </Button>

                <Button text="Orçamentos" styleClass="sidebar-item"
                        maxWidth="Infinity" onAction="#onOrcamentos">
                    <graphic><Label text="💲"/></graphic>
                </Button>

                <Button text="Ordem de serviço" styleClass="sidebar-item"
                        maxWidth="Infinity" wrapText="true"
                        onAction="#onOrdemServico">
                    <graphic><Label text="📋"/></graphic>
                </Button>

                <Button text="Relatórios" styleClass="sidebar-item, sidebar-item-active"
                        maxWidth="Infinity">
                    <graphic><Label text="📄"/></graphic>
                </Button>

                <Button text="Funcionários" styleClass="sidebar-item"
                        maxWidth="Infinity" onAction="#onFuncionarios">
                    <graphic><Label text="👥"/></graphic>
                </Button>

                <Region VBox.vgrow="ALWAYS"/>

                <Button text="Sair" styleClass="sidebar-item, sidebar-sair"
                        maxWidth="Infinity" onAction="#onSair">
                    <graphic><Label text="🚪"/></graphic>
                </Button>

            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="0">

            <HBox styleClass="header" alignment="CENTER" prefHeight="75">
                <ImageView fx:id="logoImage" fitHeight="60" preserveRatio="true">
                    <image>
                        <Image url="@../images/logo.png" />
                    </image>
                </ImageView>
            </HBox>

            <VBox styleClass="outer-panel" VBox.vgrow="ALWAYS" spacing="0">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <Label text="RELATÓRIO GERENCIAL DE FATURAMENTO" styleClass="page-title"/>

                <VBox styleClass="table-panel" VBox.vgrow="ALWAYS">

                    <HBox spacing="16" alignment="CENTER_LEFT" styleClass="table-toolbar">
                        <padding><Insets bottom="15" top="5"/></padding>

                        <HBox spacing="20" alignment="CENTER_LEFT">
                            <VBox spacing="2">
                                <Label text="Faturamento Total" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                                <Label fx:id="lblTotalFaturado" text="R$ 0,00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                            </VBox>
                            <Separator orientation="VERTICAL" prefHeight="30"/>
                            <VBox spacing="2">
                                <Label text="Total em Peças" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                                <Label fx:id="lblTotalPecas" text="R$ 0,00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
                            </VBox>
                            <Separator orientation="VERTICAL" prefHeight="30"/>
                            <VBox spacing="2">
                                <Label text="Total em Serviços" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                                <Label fx:id="lblTotalServicos" text="R$ 0,00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #8b5cf6;"/>
                            </VBox>
                            <Separator orientation="VERTICAL" prefHeight="30"/>
                            <VBox spacing="2">
                                <Label text="Clientes Atendidos" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                                <Label fx:id="lblClientesAtendidos" text="0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                            </VBox>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="🔄 Atualizar Dados" styleClass="search-icon-button"
                                style="-fx-padding: 6 12; -fx-font-size: 12px;"
                                onAction="#carregarDadosRelatorio"/>
                    </HBox>

                    <TableView fx:id="tabelaRelatorio"
                               VBox.vgrow="ALWAYS"
                               styleClass="clientes-table">

                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>

                        <columns>
                            <TableColumn fx:id="colOS"       text="Nº Orçamento" prefWidth="120"/>
                            <TableColumn fx:id="colVeiculo"  text="Veículo (Placa)" prefWidth="150"/>
                            <TableColumn fx:id="colCliente"  text="Cliente"         prefWidth="250"/>
                            <TableColumn fx:id="colData"     text="Data Fechamento" prefWidth="150"/>
                            <TableColumn fx:id="colValor"    text="Valor Total"     prefWidth="130"/>
                        </columns>

                    </TableView>

                    <HBox alignment="CENTER_RIGHT" styleClass="table-footer">
                        <Label text="*Apenas ordens Finalizadas e Pagas são calculadas neste relatório."
                               style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-font-style: italic;"/>
                    </HBox>

                </VBox>
            </VBox>
        </VBox>
    </center>

</BorderPane>