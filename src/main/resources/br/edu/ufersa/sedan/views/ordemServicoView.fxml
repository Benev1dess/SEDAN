<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.edu.ufersa.sedan.controllers.OrdemServicoController"
            stylesheets="@../css/style.css"
            prefWidth="900" prefHeight="600"
            styleClass="root">

    <left>
        <VBox styleClass="sidebar" prefWidth="160">
            <VBox spacing="0" VBox.vgrow="ALWAYS">
                <Button text="Clientes" styleClass="sidebar-item" maxWidth="Infinity" onAction="#onClientes">
                    <graphic><Label text="👤"/></graphic>
                </Button>
                <Button text="Veículos" styleClass="sidebar-item" maxWidth="Infinity" onAction="#onVeiculos">
                    <graphic><Label text="🚗"/></graphic>
                </Button>
                <Button text="Peças" styleClass="sidebar-item" maxWidth="Infinity" onAction="#onPecas">
                    <graphic><Label text="⚙"/></graphic>
                </Button>
                <Button text="Serviços" styleClass="sidebar-item" maxWidth="Infinity" onAction="#onServicos">
                    <graphic><Label text="🔧"/></graphic>
                </Button>
                <Button text="Orçamentos" styleClass="sidebar-item" maxWidth="Infinity" onAction="#onOrcamentos">
                    <graphic><Label text="💲"/></graphic>
                </Button>
                <Button text="Ordem de serviço" styleClass="sidebar-item, sidebar-item-active" maxWidth="Infinity" wrapText="true" onAction="#onOrdemServico">
                    <graphic><Label text="📋"/></graphic>
                </Button>
                <Button text="Relatórios" styleClass="sidebar-item" maxWidth="Infinity" onAction="#onRelatorios">
                    <graphic><Label text="📄"/></graphic>
                </Button>
                <Button text="Funcionários" styleClass="sidebar-item" maxWidth="Infinity" onAction="#onFuncionarios">
                    <graphic><Label text="👥"/></graphic>
                </Button>
                <Region VBox.vgrow="ALWAYS"/>
                <Button text="Sair" styleClass="sidebar-item, sidebar-sair" maxWidth="Infinity" onAction="#onSair">
                    <graphic><Label text="🚪"/></graphic>
                </Button>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="0">
            <HBox styleClass="header" alignment="CENTER" prefHeight="70">
                <ImageView fx:id="logoImage" fitHeight="55" preserveRatio="true"/>
            </HBox>

            <VBox styleClass="outer-panel" VBox.vgrow="ALWAYS" spacing="0">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <Label text="GERENCIAMENTO DE ORDENS DE SERVIÇO" styleClass="page-title"/>

                <VBox styleClass="table-panel" VBox.vgrow="ALWAYS">
                    <HBox spacing="16" alignment="CENTER_LEFT" styleClass="table-toolbar">
                        <padding><Insets bottom="10"/></padding>
                        <VBox spacing="4">
                            <CheckBox fx:id="chkPlaca" text="Placa do Veículo" styleClass="filter-checkbox" selected="true" onAction="#onFiltroChanged"/>
                            <CheckBox fx:id="chkFinalizada" text="Estado Finalizado (Sim/Não)" styleClass="filter-checkbox" selected="false" onAction="#onFiltroChanged"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox styleClass="search-box" alignment="CENTER_LEFT" spacing="4">
                            <TextField fx:id="txtBusca" promptText="Busque por placa ou estado..." styleClass="search-field" prefWidth="320" onKeyReleased="#onBuscar"/>
                            <Button text="🔍" styleClass="search-icon-button" onAction="#onBuscar"/>
                        </HBox>
                    </HBox>

                    <TableView fx:id="tabelaOS" VBox.vgrow="ALWAYS" styleClass="clientes-table">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colOrcamentoId" text="ID Orçamento" prefWidth="120"/>
                            <TableColumn fx:id="colPlaca"        text="Placa Veículo" prefWidth="150"/>
                            <TableColumn fx:id="colData"         text="Data Emissão"  prefWidth="160"/>
                            <TableColumn fx:id="colFinalizada"   text="Finalizada"    prefWidth="120"/>
                            <TableColumn fx:id="colPago"         text="Pagamento"     prefWidth="120"/>
                            <TableColumn fx:id="colAcoes"        text=""              prefWidth="100" sortable="false"/>
                        </columns>
                    </TableView>

                    <HBox alignment="CENTER_RIGHT" styleClass="table-footer">
                        <Button text="+ Emitir Nova OS" styleClass="add-button" onAction="#onAdicionar"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>