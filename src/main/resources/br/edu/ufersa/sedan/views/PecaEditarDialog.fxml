<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="br.edu.ufersa.sedan.controllers.PecaEditarController"
      stylesheets="@../css/style.css"
      styleClass="dialog-container"
      spacing="14" prefWidth="420">

    <Label text="Atualizar Dados do Item" styleClass="dialog-title"/>
    <Separator/>

    <VBox spacing="4">
        <Label text="Nome da Peça (Não modificável):" styleClass="form-label"/>
        <TextField fx:id="txtNome" styleClass="form-field" disable="true"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Fabricante:" styleClass="form-label"/>
        <TextField fx:id="txtFabricante" styleClass="form-field"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Novo Preço (R$):" styleClass="form-label"/>
        <TextField fx:id="txtPreco" styleClass="form-field"/>
    </VBox>

    <Label fx:id="lblErro" styleClass="error-label" wrapText="true"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" styleClass="btn-cancel" onAction="#onCancelar"/>
        <Button text="Atualizar" styleClass="btn-submit" onAction="#onConfirmar"/>
    </HBox>
</VBox>