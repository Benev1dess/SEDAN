                <Button maxWidth="1.7976931348623157E308" alignment="BASELINE_LEFT" style="-fx-background-color: #2D2D2D; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-graphic-text-gap: 12px;" text="Peças">
                    <graphic>
