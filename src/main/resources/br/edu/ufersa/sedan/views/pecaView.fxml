                    </graphic>
                </Button>

                <Button maxWidth="1.7976931348623157E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #8A8A8A; -fx-graphic-text-gap: 12px;" text="Relatórios">
                    <graphic>
                        <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-1 16H6v-2h12v2zm0-4H6v-2h12v2zm0-4H6V7h12v2z" fill="#8A8A8A" scaleX="0.85" scaleY="0.85" />
                    </graphic>
                </Button>

                <Button maxWidth="1.7976931348623157E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #8A8A8A; -fx-graphic-text-gap: 12px;" text="Funcionários">
                    <graphic>
