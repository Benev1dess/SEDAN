                    </graphic>
                </Button>

                <Button maxWidth="1.7976931348623157E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #8A8A8A; -fx-graphic-text-gap: 12px;" text="Serviços">
                    <graphic>
                        <SVGPath content="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.3C.5 6.7.9 9.8 2.9 11.8c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.1z" fill="#8A8A8A" scaleX="0.85" scaleY="0.85" />
                    </graphic>
                </Button>

                <Button maxWidth="1.7976931348623157E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #8A8A8A; -fx-graphic-text-gap: 12px;" text="Orçamentos">
                    <graphic>
                        <SVGPath content="M5 2H19c1.1 0 2 .9 2 2V20c0 1.1-.9 2-2 2H5c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2zm6 6H7v2h4V8zm0 4H7v2h4v-2zm6-4h-4v2h4V8zm0 4h-4v2h4v-2z" fill="#8A8A8A" scaleX="0.85" scaleY="0.85" />
