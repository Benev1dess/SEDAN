                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <VBox BorderPane.alignment="CENTER">
            <children>

                <HBox alignment="CENTER" prefHeight="60.0" style="-fx-background-color: #C00000;" />

                <VBox spacing="15.0" style="-fx-background-color: #DCDCDC; -fx-padding: 25px;" VBox.vgrow="ALWAYS">
                    <children>
                        <Label text="GERENCIAMENTO DE PEÇAS" textFill="#333333">
                            <font>
                                <Font name="Arial Bold" size="16.0" />
                            </font>
                        </Label>

                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <VBox spacing="8.0">
                                    <children>
                                        <CheckBox fx:id="chkFabricante" selected="true" text="Fabricante" style="-fx-text-fill: #333333; -fx-font-weight: bold;" />
                                        <CheckBox fx:id="chkAutomovel" selected="true" text="Automóvel" style="-fx-text-fill: #333333; -fx-font-weight: bold;" />
                                        <CheckBox fx:id="chkNome" selected="true" text="Nome" style="-fx-text-fill: #333333; -fx-font-weight: bold;" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <TextField fx:id="searchField" promptText="Busque por nome, fabricante ou automóvel..." prefWidth="380.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #CCCCCC; -fx-padding: 8px;" />
                            </children>
                        </HBox>

                        <TableView fx:id="tabelaPecas" style="-fx-background-color: #FFFFFF;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colNome" text="Nome" />
                                <TableColumn fx:id="colPreco" text="Preço" />
                                <TableColumn fx:id="colFabricante" text="Fabricante" />
                                <TableColumn fx:id="colCarro" text="Carro" />
                                <TableColumn fx:id="colCliente" text="Cliente" />
                                <TableColumn fx:id="colAcoes" prefWidth="120.0" text="Ações" style="-fx-alignment: CENTER;" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Button fx:id="btnAdicionar" mnemonicParsing="false" style="-fx-background-color: #FFFFFF; -fx-border-color: #BBBBBB; -fx-border-radius: 4px; -fx-padding: 8px 15px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="+ Adicionar peças" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>