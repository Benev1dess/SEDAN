                    </graphic>
                </Button>

                <Region VBox.vgrow="ALWAYS" />

                <Button style="-fx-background-color: transparent; -fx-text-fill: #8A8A8A; -fx-graphic-text-gap: 12px;" text="Sair">
                    <graphic>
                        <SVGPath content="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" fill="#8A8A8A" scaleX="0.85" scaleY="0.85" />
