<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="br.edu.ufersa.sedan.controllers.VeiculoAdicionarController"
      stylesheets="@../css/style.css"
      styleClass="dialog-root"
      prefWidth="540" spacing="0">

    <padding><Insets top="28" right="28" bottom="24" left="28"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Adicionar Veículo" styleClass="dialog-title"/>
        <Label text="+" styleClass="dialog-title-icon"/>
    </HBox>

    <VBox spacing="0">
        <padding><Insets top="18" bottom="0"/></padding>

        <Label text="NOME DO CLIENTE JÁ CADASTRADO" styleClass="dialog-field-label"/>

        <AnchorPane>
            <VBox.margin><Insets top="4" bottom="16"/></VBox.margin>

            <HBox styleClass="dialog-search-box" alignment="CENTER_LEFT" spacing="4"
                  AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                <TextField fx:id="txtBuscaCliente"
                           styleClass="dialog-search-field"
                           HBox.hgrow="ALWAYS"
                           onKeyReleased="#onBuscarCliente"/>
                <Button text="🔍" styleClass="dialog-search-icon" onAction="#onBuscarCliente"/>
            </HBox>

            <ListView fx:id="listaSugestoes"
                      styleClass="dialog-suggestions"
                      prefHeight="180"
                      maxHeight="200"
                      visible="false"
                      managed="false"
                      AnchorPane.topAnchor="42.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"/>
        </AnchorPane>

        <GridPane hgap="14" vgap="0">
            <columnConstraints>
                <ColumnConstraints percentWidth="33.3"/>
                <ColumnConstraints percentWidth="33.3"/>
                <ColumnConstraints percentWidth="33.3"/>
            </columnConstraints>

            <Label text="AUTOMÓVEL" styleClass="dialog-field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label text="PLACA"     styleClass="dialog-field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <Label text="MARCA"     styleClass="dialog-field-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>

            <TextField fx:id="tfAutomovel" styleClass="dialog-field" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="tfPlaca"     styleClass="dialog-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <TextField fx:id="tfMarca"     styleClass="dialog-field" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

            <Region GridPane.columnIndex="0" GridPane.rowIndex="2" prefHeight="12"/>

            <Label text="ANO"     styleClass="dialog-field-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <Label text="KM"      styleClass="dialog-field-label" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <TextField fx:id="tfAno"     styleClass="dialog-field" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <TextField fx:id="tfKm"      styleClass="dialog-field" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        </GridPane>
    </VBox>

    <Label fx:id="lblErro" styleClass="dialog-error" wrapText="true">
        <VBox.margin><Insets top="8"/></VBox.margin>
    </Label>

    <Button text="ADICIONAR NOVO CLIENTE"
            styleClass="dialog-btn-blue"
            maxWidth="Infinity"
            onAction="#onAdicionarNovoCliente">
        <VBox.margin><Insets top="16"/></VBox.margin>
    </Button>

    <HBox spacing="14" alignment="CENTER">
        <VBox.margin><Insets top="16"/></VBox.margin>
        <Button text="CANCELAR"  styleClass="dialog-btn-red"   prefWidth="180" onAction="#onCancelar"/>
        <Button text="CONFIRMAR" styleClass="dialog-btn-green" prefWidth="180" onAction="#onConfirmar"/>
    </HBox>

</VBox>